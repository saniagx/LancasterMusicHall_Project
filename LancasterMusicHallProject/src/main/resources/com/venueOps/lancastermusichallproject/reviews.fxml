<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #122023;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.venueOps.lancastermusichallproject.operations.Reviews">
    <children>
        <AnchorPane layoutX="128.0" layoutY="73.0" prefHeight="576" prefWidth="1024" style="-fx-background-color: #FFFFFF; -fx-background-radius: 20px;">
            <children>
                <Label layoutX="441.0" prefHeight="65.0" prefWidth="164.0" text="Reviews" textAlignment="CENTER">
                    <font>
                        <Font name="System Bold" size="36.0" />
                    </font>
                </Label>
                <Button layoutX="14.0" layoutY="15.0" onAction="#BackButton" prefHeight="35.0" prefWidth="165" style="-fx-background-color: #122023; -fx-background-radius: 29px;" text="Back to Main Menu" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
                <AnchorPane layoutX="19.0" layoutY="66.0" prefHeight="491.0" prefWidth="975.0">
                    <children>
                        <TableView fx:id="reviewTable" prefHeight="489.0" prefWidth="975.0">
                            <columns>
                                <TableColumn fx:id="Booking_ID" prefWidth="130.0" text="Booking ID" />
                                <TableColumn fx:id="Event_ID" prefWidth="130.0" text="Event ID" />
                                <TableColumn fx:id="Event_Name" prefWidth="400.0" text="Event Name" />
                                <TableColumn fx:id="View_Button" prefWidth="150.0" text="Reviews" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </AnchorPane>
            </children>
        </AnchorPane>
    </children>
</AnchorPane>
