<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #122023;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.venueOps.lancastermusichallproject.operations.Calendar">
   <children>

      <!-- Day Row -->
      <AnchorPane layoutX="128" layoutY="73" prefHeight="576" prefWidth="1024" style="-fx-background-color: #FFFFFF; -fx-background-radius: 20px;">
         <children>
            <HBox alignment="CENTER" layoutX="37.0" layoutY="90.0" prefHeight="35.0" prefWidth="800.0">
               <children>
                  <Label alignment="CENTER" prefWidth="114.0" style="     -fx-font-size: 18px;-fx-font-weight: bold;-fx-text-fill: #333;     -fx-border-color: transparent transparent #cccccc transparent;   -fx-border-width: 0 0 2px 0;   -fx-border-insets: 0 15 0 15;  -fx-padding: 0 0 4px 0; " text="Mon" />
                  <Label alignment="CENTER" prefWidth="114.0" style="     -fx-font-size: 18px;-fx-font-weight: bold;-fx-text-fill: #333;     -fx-border-color: transparent transparent #cccccc transparent;   -fx-border-width: 0 0 2px 0;   -fx-border-insets: 0 15 0 15;  -fx-padding: 0 0 4px 0; " text="Tue" />
                  <Label alignment="CENTER" prefWidth="114.0" style="     -fx-font-size: 18px;-fx-font-weight: bold;-fx-text-fill: #333;     -fx-border-color: transparent transparent #cccccc transparent;   -fx-border-width: 0 0 2px 0;   -fx-border-insets: 0 15 0 15;  -fx-padding: 0 0 4px 0; " text="Wed" />
                  <Label alignment="CENTER" prefWidth="114.0" style="     -fx-font-size: 18px;-fx-font-weight: bold;-fx-text-fill: #333;     -fx-border-color: transparent transparent #cccccc transparent;   -fx-border-width: 0 0 2px 0;   -fx-border-insets: 0 15 0 15;  -fx-padding: 0 0 4px 0; " text="Thu" />
                  <Label alignment="CENTER" prefWidth="114.0" style="     -fx-font-size: 18px;-fx-font-weight: bold;-fx-text-fill: #333;     -fx-border-color: transparent transparent #cccccc transparent;   -fx-border-width: 0 0 2px 0;   -fx-border-insets: 0 15 0 15;  -fx-padding: 0 0 4px 0; " text="Fri" />
                  <Label alignment="CENTER" prefWidth="114.0" style="     -fx-font-size: 18px;-fx-font-weight: bold;-fx-text-fill: #333;     -fx-border-color: transparent transparent #cccccc transparent;   -fx-border-width: 0 0 2px 0;   -fx-border-insets: 0 15 0 15;  -fx-padding: 0 0 4px 0; " text="Sat" />
                  <Label alignment="CENTER" prefWidth="114.0" style="     -fx-font-size: 18px;-fx-font-weight: bold;-fx-text-fill: #333;     -fx-border-color: transparent transparent #cccccc transparent;   -fx-border-width: 0 0 2px 0;   -fx-border-insets: 0 15 0 15;  -fx-padding: 0 0 4px 0; " text="Sun" />
               </children>
            </HBox>
            <!-- Title -->
            <Text layoutX="437.0" layoutY="59.0" text="Calendar">
               <font>
                  <Font name="System Bold" size="36.0" />
               </font>
            </Text>

            <!-- Back Button -->
            <Button layoutX="25.0" layoutY="27.0" onAction="#BackButton" prefHeight="35" prefWidth="165" style="-fx-background-color: #122023; -fx-background-radius: 29px;" text="Back to Main Menu" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Button>

            <!-- Navigation Controls -->
            <HBox alignment="CENTER" layoutX="811.0" layoutY="90.0" prefHeight="35.0" prefWidth="237.0" spacing="10">
               <children>
                  <Button onAction="#goToPreviousMonth" style=" -fx-background-color: transparent; -fx-font-size: 16px; -fx-text-fill: #333;-fx-cursor: hand;" text="❮" />
                  <Label fx:id="monthYearLabel" alignment="CENTER" style="-fx-font-size: 20px;-fx-font-weight: bold;-fx-text-fill: #222;" text="April 2025" />
                  <Button onAction="#goToNextMonth" style="-fx-background-color: transparent; -fx-font-size: 16px; -fx-text-fill: #333; -fx-cursor: hand;" text="❯" />
               </children>
            </HBox>

            <!-- Grid container for calendar -->
            <GridPane fx:id="calendarGrid" hgap="15" layoutX="37.0" layoutY="125.0" prefHeight="425.0" prefWidth="800" style="-fx-background-color: transparent;" vgap="15">
            </GridPane>
            <Button layoutX="855.0" layoutY="142.0" onAction="#NewBooking" prefHeight="35" prefWidth="150.0" style="-fx-background-color: #122023; -fx-background-radius: 29px;" text="New Booking" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Button>
            <Button layoutX="855.0" layoutY="189.0" onAction="#ViewBookings" prefHeight="35" prefWidth="150.0" style="-fx-background-color: #122023; -fx-background-radius: 29px;" text="View Bookings" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Button>
            <TextArea fx:id="diaryPreviewArea" editable="false" layoutX="847.0" layoutY="238.0" prefHeight="313.0" prefWidth="165.0" promptText="Click a date to preview note..." wrapText="true" />

         </children>
      </AnchorPane>
   </children>
</AnchorPane>
