<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #122023;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.venueOps.lancastermusichallproject.operations.Calendar">
   <children>

      <!-- White card in the center -->
      <AnchorPane layoutX="128" layoutY="73" prefHeight="576" prefWidth="1024" style="-fx-background-color: #FFFFFF; -fx-background-radius: 20px;">
         <children>
            <HBox alignment="CENTER" layoutX="100.0" layoutY="90.0" prefHeight="35.0" prefWidth="800.0">
               <children>
                  <Label alignment="CENTER" prefWidth="114.0" text="Mon">
                     <font>
                        <Font size="24.0" />
                     </font>
                  </Label>
                  <Label alignment="CENTER" prefWidth="114.0" text="Tue">
                     <font>
                        <Font size="24.0" />
                     </font>
                  </Label>
                  <Label alignment="CENTER" prefWidth="114.0" text="Wed">
                     <font>
                        <Font size="24.0" />
                     </font>
                  </Label>
                  <Label alignment="CENTER" prefWidth="114.0" text="Thu">
                     <font>
                        <Font size="24.0" />
                     </font>
                  </Label>
                  <Label alignment="CENTER" prefWidth="114.0" text="Fri">
                     <font>
                        <Font size="24.0" />
                     </font>
                  </Label>
                  <Label alignment="CENTER" prefWidth="114.0" text="Sat">
                     <font>
                        <Font size="24.0" />
                     </font>
                  </Label>
                  <Label alignment="CENTER" prefHeight="35.0" prefWidth="114.0" text="Sun">
                     <font>
                        <Font size="24.0" />
                     </font>
                  </Label>
               </children>
            </HBox>

            <!-- Title -->
            <Text layoutX="437.0" layoutY="56.0" text="Calendar">
               <font>
                  <Font name="System Bold" size="36.0" />
               </font>
            </Text>

            <!-- Back Button -->
            <Button layoutX="25.0" layoutY="27.0" onAction="#BackButton" prefHeight="35" prefWidth="165" style="-fx-background-color: #122023; -fx-background-radius: 29px;" text="Back to Main Menu" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Button>

            <!-- Navigation Controls -->
            <HBox alignment="CENTER_RIGHT" layoutX="735.0" layoutY="62.0" prefHeight="25.0" prefWidth="165.0" spacing="10">
               <children>
                  <Button onAction="#goToPreviousMonth" text="&lt;" />
                  <Label fx:id="monthYearLabel" alignment="CENTER" text="Month Year" />
                  <Button alignment="CENTER_RIGHT" onAction="#goToNextMonth" text="&gt;" />
               </children></HBox>

            <!-- Grid container for calendar -->
            <GridPane fx:id="calendarGrid" hgap="5" layoutX="100" layoutY="122.0" prefHeight="425.0" prefWidth="800" style="-fx-background-color: #f9f9f9;" vgap="5">
            </GridPane>

         </children>
      </AnchorPane>
   </children>
</AnchorPane>
