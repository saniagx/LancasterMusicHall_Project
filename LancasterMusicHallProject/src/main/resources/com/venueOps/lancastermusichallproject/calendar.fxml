<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #122023;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.venueOps.lancastermusichallproject.operations.Calendar">
   <children>

      <!-- White card in the center -->
      <AnchorPane layoutX="128" layoutY="73" prefHeight="576" prefWidth="1024" style="-fx-background-color: #FFFFFF; -fx-background-radius: 20px;">
         <children>

            <!-- Title -->
            <Text layoutX="437.0" layoutY="56.0" text="Calendar">
               <font>
                  <Font name="System Bold" size="36.0" />
               </font>
            </Text>

            <!-- Back Button -->
            <Button layoutX="25.0" layoutY="27.0" onAction="#BackButton" prefHeight="35" prefWidth="165" style="-fx-background-color: #122023; -fx-background-radius: 29px;" text="Back to Main Menu" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Button>

            <!-- Navigation Controls -->
            <HBox layoutX="300" layoutY="80" spacing="10" />

            <!-- Grid container for calendar -->
            <GridPane fx:id="calendarGrid" hgap="5" layoutX="100" layoutY="130" prefHeight="400" prefWidth="800" style="-fx-background-color: #f9f9f9;" vgap="5">
            </GridPane>
            <Button layoutX="768.0" layoutY="87.0" onAction="#goToPreviousMonth" text="&lt;" />
            <Label fx:id="monthYearLabel" layoutX="803.0" layoutY="87.0" text="Month Year" />
            <Button layoutX="875.0" layoutY="87.0" onAction="#goToNextMonth" text="&gt;" />

         </children>
      </AnchorPane>
   </children>
</AnchorPane>
