<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #122023;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.venueOps.lancastermusichallproject.operations.ReviewsPage">
    <children>
        <AnchorPane layoutX="128.0" layoutY="73.0" prefHeight="576" prefWidth="1024" style="-fx-background-color: #FFFFFF; -fx-background-radius: 20px;">
            <children>
                <Label layoutX="441.0" prefHeight="65.0" prefWidth="164.0" text="Review Page" textAlignment="CENTER">
                    <font>
                        <Font name="System Bold" size="36.0" />
                    </font>
                </Label>
                <Button layoutX="14.0" layoutY="15.0" onAction="#BackButton" prefHeight="35.0" prefWidth="165" style="-fx-background-color: #122023; -fx-background-radius: 29px;" text="Back to All Reviews" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
                <Button fx:id="exportPDF" layoutX="825.0" layoutY="15.0" onAction="#exportPDF" prefHeight="35.0" prefWidth="165" style="-fx-background-color: #FFFFFF; -fx-border-color: #122023; -fx-background-radius: 29px; -fx-border-radius: 29px;" text="Export as PDF" textFill="#122023">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
                <TableView fx:id="reviewsTable" layoutX="40.0" layoutY="100.0" prefHeight="430.0" prefWidth="940.0">
                    <columns>
                        <TableColumn fx:id="Reviewer_Name" prefWidth="150.0" text="Reviewer" />
                        <TableColumn fx:id="Rating" prefWidth="100.0" text="Rating" />
                        <TableColumn fx:id="Comment" prefWidth="500.0" text="Comment" />
                        <TableColumn fx:id="Date_Posted" prefWidth="150.0" text="Date Posted" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </AnchorPane>
    </children>
</AnchorPane>
