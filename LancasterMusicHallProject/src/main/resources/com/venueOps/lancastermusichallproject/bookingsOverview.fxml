<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #122023;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.venueOps.lancastermusichallproject.operations.BookingsOverview">
   <children>
      <AnchorPane layoutX="128.0" layoutY="73.0" prefHeight="576" prefWidth="1024" style="-fx-background-color: #FFFFFF; -fx-background-radius: 20px;">
         <children>
            <Text layoutX="433.0" layoutY="46.0" text="Bookings">
               <font>
                  <Font name="System Bold" size="36.0" />
               </font>
            </Text>
            <Button layoutX="14.0" layoutY="14.0" onAction="#BackButton" prefHeight="35" prefWidth="165" style="-fx-background-color: #122023; -fx-background-radius: 29px;" text="Back to Calendar" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Button>
            <TabPane fx:id="tabPane" layoutY="66.0" prefHeight="511.0" prefWidth="1024.0" style="-fx-background-radius: 20px;" tabClosingPolicy="UNAVAILABLE">
               <tabs>
                  <Tab fx:id="events_Tab" closable="false" text="Bookings">
                     <content>
                        <AnchorPane prefHeight="200.0" prefWidth="200.0">
                           <children>
                              <TableView fx:id="bookingsTable" prefHeight="385.0" prefWidth="1025.0">
                                <columns>
                                  <TableColumn fx:id="bookingIDColumn" prefWidth="68.0" text="Booking ID" />
                                  <TableColumn fx:id="companyNameColumn" prefWidth="119.0" text="Company Name" />
                                    <TableColumn fx:id="contactNameColumn" prefWidth="124.0" text="Contact Name" />
                                    <TableColumn fx:id="emailColumn" prefWidth="127.0" text="Email" />
                                    <TableColumn fx:id="phoneColumn" prefWidth="133.0" text="Phone Number" />
                                    <TableColumn fx:id="signedDateColumn" prefWidth="121.0" text="Signed Date" />
                                    <TableColumn fx:id="startDateColumn" prefWidth="115.0" text="Start Date" />
                                    <TableColumn fx:id="endDateColumn" prefWidth="108.0" text="End Date" />
                                    <TableColumn fx:id="statusColumn" prefWidth="109.0" text="Status" />
                                </columns>
                              </TableView>
                              <Button layoutX="430.0" layoutY="421.0" onAction="#CancelBooking" prefHeight="35" prefWidth="165" style="-fx-background-color: #122023; -fx-background-radius: 29px;" text="Cancel Booking" textFill="WHITE">
                                 <font>
                                    <Font name="System Bold" size="13.0" />
                                 </font>
                              </Button>
                           </children>
                        </AnchorPane>
                     </content>
                  </Tab>
                  <Tab fx:id="eventsTab" closable="false" disable="true" text="Events">
                     <content>
                        <AnchorPane prefHeight="200.0" prefWidth="240.0">
                           <children>
                              <ScrollPane layoutY="31.0" prefHeight="420.0" prefWidth="1024.0" styleClass="events_list-scrollpane" stylesheets="@css.css">
                                 <content>
                                    <GridPane fx:id="eventsGridPane" alignment="TOP_CENTER" hgap="15.0" prefHeight="418.0" prefWidth="1022.0" vgap="15.0">
                                       <columnConstraints>
                                          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                       </columnConstraints>
                                       <rowConstraints>
                                          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                       </rowConstraints>
                                    </GridPane>
                                 </content>
                              </ScrollPane>
                           </children></AnchorPane>
                     </content>
                  </Tab>
               </tabs>
            </TabPane>
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
