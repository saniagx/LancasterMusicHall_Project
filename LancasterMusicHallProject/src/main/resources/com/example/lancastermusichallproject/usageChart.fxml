<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="720.0" maxWidth="1280.0" prefHeight="540.0" prefWidth="960.0" style="-fx-background-color: #122033;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.lancastermusichallproject.usageChartController">
    <children>
        <TableView fx:id="venueTable" layoutY="32.0" maxHeight="510.0" maxWidth="200.0" prefHeight="510.0" prefWidth="200.0">
            <columns>
                <TableColumn fx:id="venueColumn" maxWidth="200.0" prefWidth="200.0" text="Venue" />
            </columns>
        </TableView>
        <Button layoutY="-3.0" mnemonicParsing="false" onAction="#BackButton" text="Back">
            <font>
                <Font size="16.0" />
            </font>
        </Button>
        <Canvas fx:id="chartCanvas" height="510.0" layoutX="200.0" layoutY="32.0" width="760.0" />
    </children>
</AnchorPane>
